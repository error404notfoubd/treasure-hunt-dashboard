# ═══════════════════════════════════════════════════════════
#  TREASURE HUNT DASHBOARD — Environment Variables
#  Copy this file to .env.local and fill in your values.
# ═══════════════════════════════════════════════════════════

# ── Supabase (single project) ──
# Project Settings → API → Publishable and secret API keys

# Server-side (never exposed to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-secret-key-here
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Client-side copies (NEXT_PUBLIC_ prefix exposes to browser — publishable key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# ── Domain lock ──
# Comma-separated hostnames (no https://). Ports are ignored (e.g. localhost:3000 → localhost).
# Include localhost (and 127.0.0.1 if you use it) for local dev alongside production.
# Vercel: when this var is set, VERCEL_URL is also allowed as an extra hostname.
# Omit entirely to disable the lock (all hosts allowed).
ALLOWED_DOMAIN=localhost,127.0.0.1,your-project.vercel.app
